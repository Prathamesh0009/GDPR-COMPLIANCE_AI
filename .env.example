# Copy to .env and fill in real values (never commit .env).

# Required for LLM calls (analyze, assess, translations)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Optional paths
# CHROMA_PATH=./data/chroma
# SQLITE_PATH=./data/app.db
# BM25_INDEX_PATH=./data/processed/bm25.pkl
# PROCESSED_DIR=./data/processed
# LOG_DB_PATH=./logs/gdpr_ai.db

# Model IDs (defaults match gdpr-ai v2)
# MODEL_REASONING=claude-sonnet-4-6
# MODEL_EXTRACT_CLASSIFY=claude-haiku-4-5-20251001
# MODEL_TRANSLATION=claude-haiku-4-5-20251001

# EMBEDDING_MODEL=BAAI/bge-m3
# MAX_TOKENS=16384
# TOP_K=25
# LOG_LEVEL=INFO
